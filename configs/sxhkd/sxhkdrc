super + alt + {q,r}
	bspc {quit,wm -r}

super + Return
    wezterm

super + d
    rofi -show drun -theme launcher

super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

super + {_,shift + }q
    bspc node -{c,k}

super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} focused:'^{1-9,10}'
